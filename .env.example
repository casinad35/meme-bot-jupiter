# =============================================================================
# MEME COIN TRADING BOT - ENVIRONMENT CONFIGURATION
# Copy this file to `.env` and fill in your values. Never commit `.env` to git.
# =============================================================================

# -----------------------------------------------------------------------------
# MODE
# -----------------------------------------------------------------------------
# "paper"  -> simulated trading, no real swaps, safe for testing
# "live"   -> real on-chain swaps. Use only after thorough paper testing.
TRADING_MODE=paper

# -----------------------------------------------------------------------------
# SOLANA RPC / WEBSOCKET (Helius recommended)
# Sign up at https://helius.dev to get an API key.
# -----------------------------------------------------------------------------
HELIUS_API_KEY=your_helius_api_key_here
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Optional: additional Helius API keys for automatic failover. When the
# active key hits 429 / quota exhaustion, the bot rotates to the next one.
# Comma-separated list of bare keys (not full URLs). Useful for stretching
# the free 1M credits/month tier across multiple Helius accounts.
# Example: HELIUS_API_KEYS=11111111-2222-3333-4444-555555555555,aaaaaaaa-...
HELIUS_API_KEYS=

# -----------------------------------------------------------------------------
# WALLET (LIVE MODE ONLY)
# Use a DEDICATED hot wallet with limited funds. Never use your main wallet.
# Provide either a base58 private key or a path to a Solana CLI keypair JSON.
# -----------------------------------------------------------------------------
WALLET_PRIVATE_KEY_BASE58=
WALLET_KEYPAIR_PATH=

# -----------------------------------------------------------------------------
# SECURITY APIS
# -----------------------------------------------------------------------------
# GoPlus Security: https://gopluslabs.io/  (free tier available)
GOPLUS_API_KEY=

# Jupiter: https://portal.jup.ag/
# Used for token metadata (liquidity / mcap / holders / authorities) and
# real-time price polling. Without a key the bot falls back to lite-api.jup.ag
# (free, lower rate limits). With a key it uses api.jup.ag for higher limits.
JUPITER_API_KEY=

# -----------------------------------------------------------------------------
# TELEGRAM NOTIFICATIONS
# Create a bot via @BotFather, get the token. Get your chat_id from @userinfobot.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
# Set to true to receive a Telegram message for every shield REJECT.
# Useful for debugging the filter, noisy in production. Default false.
TELEGRAM_NOTIFY_REJECTS=false

# -----------------------------------------------------------------------------
# TRADING PARAMETERS
# -----------------------------------------------------------------------------
# Amount of SOL to spend per trade
TRADE_SIZE_SOL=0.1

# Maximum number of simultaneous open positions
MAX_OPEN_POSITIONS=3

# Slippage tolerance in basis points (100 = 1%)
SLIPPAGE_BPS=1500

# Priority fee in micro-lamports (helps tx land in busy markets)
PRIORITY_FEE_MICROLAMPORTS=200000

# Optional safety stop-loss before reaching 2x (set 0 to disable)
# 0.5 means: sell everything if price drops to 50% of entry before any TP hit
HARD_STOP_LOSS_RATIO=0.5

# Maximum hold time for a position in minutes (auto-exit if reached)
MAX_HOLD_MINUTES=240

# -----------------------------------------------------------------------------
# RISK MANAGEMENT (LIVE MODE)
# -----------------------------------------------------------------------------
# Maximum realized drawdown (as fraction of wallet capital) before the bot
# stops opening new positions. 0.5 = stop at -50%. Set to 1.0 to disable.
# Existing positions can still close after the brake engages.
MAX_DRAWDOWN_PCT=0.5

# Number of consecutive failed swap transactions before triggering a cooldown.
# Rugs, MEV sandwiches, and dead pools tend to cluster.
TX_FAILURE_THRESHOLD=3

# Cooldown duration after a failure streak, in seconds.
TX_FAILURE_COOLDOWN_S=300

# Override the auto-detected initial wallet capital used as the drawdown
# baseline. 0 = auto-detect from the live wallet at startup. Useful for
# paper mode (set to e.g. 1.0 to simulate a 1 SOL bankroll).
INITIAL_CAPITAL_SOL_OVERRIDE=0

# -----------------------------------------------------------------------------
# SECURITY FILTERS (THE SHIELD)
# -----------------------------------------------------------------------------
# Reject token if any single non-LP holder owns more than this fraction
MAX_TOP_HOLDER_PCT=0.05

# Number of top holders to inspect for cluster detection
HOLDERS_TO_INSPECT=20

# Minimum USD liquidity required in the pool
MIN_LIQUIDITY_USD=8000

# Maximum USD liquidity (filter out blue chips, focus on memes)
MAX_LIQUIDITY_USD=2000000

# Minimum number of buy transactions in the first 30 seconds before entry
MIN_EARLY_BUYS=3

# Maximum age of a pool when first considering it (seconds)
MAX_POOL_AGE_SECONDS=120

# Reject candidates whose LP lock/burn status can't be proven on chain.
# This was the cause of our first live rug (WorldCup): shield passed at
# t=0 with a "lp_lock_status_unknown" warning, pool drained at t=27min.
# Default true. Setting to false reverts to warning-only.
REQUIRE_LP_LOCK_PROOF=true

# When the price feed rejects on-chain prices as "absurd" (drained vault,
# migration, etc) for this many consecutive ticks, force-close the
# position. 30 ticks * 4s = 2min of garbage prices = definitely dead pool.
ABSURD_PRICE_FORCE_CLOSE_TICKS=30

# Cluster (funding-graph) check on top holders. Most expensive shield step
# (~30 RPC calls per evaluated token). Off by default; the on-chain
# concentration check alone catches most rugs.
ENABLE_CLUSTER_CHECK=false

# Skip re-evaluating mints we've already seen recently (seconds). A single
# mint can show up across multiple pools (Raydium V4 + CPMM + Orca, etc.)
# within a short window — caching the verdict saves a lot of RPC.
SHIELD_CACHE_SECONDS=60

# -----------------------------------------------------------------------------
# RUNTIME
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
DATA_DIR=data
